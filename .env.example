# Google Analytics 4 Measurement ID
# Get yours at https://analytics.google.com → Admin → Data Streams → Web
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID — loaded only after marketing consent
# Get yours at https://business.facebook.com → Events Manager
# Format: numeric ID string (e.g. 1234567890123456)
NEXT_PUBLIC_META_PIXEL_ID=

# LinkedIn Insight Tag partner ID — loaded only after marketing consent
# Get yours at https://www.linkedin.com/campaignmanager → Insight Tag
# Format: numeric ID string
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=

# RB2B B2B visitor-identification key — loaded only after marketing consent
# Get yours at https://rb2b.com dashboard
# Format: account-specific key
NEXT_PUBLIC_RB2B_KEY=

# Set to "true" once Google OAuth is enabled in Supabase → Authentication → Providers.
# While unset/false, the "Continue with Google" button is hidden so users don't hit
# a "provider is not enabled" error page.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=
